NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: override privacy statement .txt URL (defaults to {NEXT_PUBLIC_SUPABASE_URL}/storage/v1/object/public/Webpage_statements/privacy_statment.txt)
# NEXT_PUBLIC_PRIVACY_STATEMENT_URL=https://your-project.supabase.co/storage/v1/object/public/Webpage_statements/privacy_statment.txt
# Optional: full URL for quiz page mascot; defaults to .../public/Webpage_images/logo/logo_banana_student.png on same project
# NEXT_PUBLIC_MASCOT_IMAGE_URL=https://your-project.supabase.co/storage/v1/object/public/...
# Optional: use service role in /api/cron-recalculate-averages (higher PostgREST limits)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# CRON_SECRET=generate-a-32+-char-random-secret
# Admin console server-side credentials (required)
# ADMIN_CONSOLE_USER=your-admin-username
# ADMIN_CONSOLE_PASS=your-admin-password
# ADMIN_SESSION_SECRET=generate-a-64+-char-random-secret
